<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="" readonly="0" foreign_keys="" case_sensitive_like="" temp_store="" wal_autocheckpoint="" synchronous=""/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="1579"/><column_width id="4" width="0"/></tab_structure><tab_browse><table title="users" custom_title="0" dock_id="1" table="0,0:"/><dock_state state="000000ff00000000fd0000000100000002000002290000020afc0100000001fb000000160064006f0063006b00420072006f00770073006500310100000000000002290000011a00ffffff000002290000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings/></tab_browse><tab_sql><sql name="SQL 1*">
CREATE TABLE IF NOT EXISTS users(
users_id INTEGER PRIMARY KEY AUTOINCREMENT,
email TEXT UNIQUE,
telefoonnummer TEXT,
first_name TEXT NOT NULL,
last_name TEXT NOT NULL,
wachtwoord TEXT NOT NULL,
profile_picture TEXT,
birthdate DATE,
created_at DATETIME
);

CREATE TABLE IF NOT EXISTS messages(
    message_id INTEGER PRIMARY KEY,
    sender_id INTEGER,
    receiver_id INTEGER,
    content TEXT,
    sent_at DATETIME,
    is_read BOOLEAN,
    FOREIGN KEY (sender_id) REFERENCES user(user_id),
    FOREIGN KEY (receiver_id) REFERENCES user(user_id)
);

CREATE TABLE IF NOT EXISTS planner(
    planner_id INTEGER PRIMARY KEY,
    title TEXT,
    description TEXT,
    start_dateTime DATETIME,
    end_dateTime DATETIME
);

CREATE TABLE IF NOT EXISTS planner_user(
    planner_user_id INTEGER PRIMARY KEY,
    planner_id INTEGER,
    user_id INTEGER,
    role TEXT,
    status TEXT,
    FOREIGN KEY (planner_id) REFERENCES planner(planner_id),
    FOREIGN KEY (user_id) REFERENCES user(user_id)
);

CREATE TABLE IF NOT EXISTS availability(
    availability_id INTEGER PRIMARY KEY,
    user_id INTEGER,
    start_dateTime DATETIME,
    end_dateTime DATETIME,
    FOREIGN KEY (user_id) REFERENCES user(user_id)
);</sql><current_tab id="0"/></tab_sql></sqlb_project>
